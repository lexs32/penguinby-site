<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Orbitron:wght@400;700;800;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050608;
    --fg: #f6f1ec;
    --muted: #8A9BB0;
    --primary: #f6f1ec;
  }
  html, body { background: var(--bg) !important; color: var(--fg) !important; font-family: 'Rajdhani', system-ui, sans-serif; }
  .font-orbitron { font-family: 'Orbitron', sans-serif; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }
  .text-muted { color: var(--muted); }
  .text-primary { color: var(--primary); }
  .bg-primary { background: var(--primary); }
  .site-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 58px 58px;
  }
  @keyframes grid-pan { from { background-position: 0 0; } to { background-position: 58px 58px; } }
  .animate-grid-pan { animation: grid-pan 18s linear infinite; }
  @keyframes scan { 0% { transform: translateY(-100%); } 100% { transform: translateY(200%); } }
  .animate-scan { animation: scan 4s ease-in-out infinite; }
  @keyframes fade-up { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-up { animation: fade-up 0.7s ease-out both; }
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .glass { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(20px); }
  .btn-primary { background: var(--primary); color: #0b0b0d; transition: all 0.2s; cursor: pointer; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 30px rgba(246,241,236,0.25); }
  .btn-ghost { border: 1px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.85); transition: all 0.2s; cursor: pointer; }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.45); color: #fff; }
  .modal-backdrop { display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); align-items: center; justify-content: center; padding: 1.5rem; }
  .modal-backdrop.open { display: flex; }
  .modal-card { max-width: 720px; width: 100%; max-height: 80vh; overflow-y: auto; background: #0b0b0d; border: 1px solid rgba(246,241,236,0.2); border-radius: 14px; padding: 2rem; }
  #mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(5,6,8,0.97); backdrop-filter: blur(24px); flex-direction: column; align-items: center; justify-content: center; gap: 2rem; }
  #mobile-menu.open { display: flex; }
  #mobile-menu a, #mobile-menu button { font-family: 'Orbitron', sans-serif; font-size: 1.4rem; font-weight: 800; color: #fff; text-decoration: none; background: none; border: none; cursor: pointer; }
  #mobile-menu a:hover, #mobile-menu button:hover { color: var(--muted); }
  #back-to-top { position: fixed; bottom: 2rem; right: 2rem; z-index: 998; width: 44px; height: 44px; border-radius: 50%; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transform: translateY(12px); transition: all 0.3s; pointer-events: none; font-size: 1.2rem; }
  #back-to-top.show { opacity: 1; transform: translateY(0); pointer-events: auto; }
  #back-to-top:hover { background: rgba(255,255,255,0.15); }
  @keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 8px rgba(34,197,94,0.3); } 50% { box-shadow: 0 0 20px rgba(34,197,94,0.6); } }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 8px; }
  .status-dot.green { background: #22c55e; animation: pulse-glow 2s ease-in-out infinite; }
  .status-dot.yellow { background: #eab308; }
  .status-dot.red { background: #ef4444; }
</style>

<div class="fixed inset-0 site-grid animate-grid-pan opacity-50 pointer-events-none" style="z-index:0;"></div>
<div class="fixed right-[-16rem] top-[-14rem] h-[42rem] w-[42rem] rounded-full bg-white/[0.05] blur-[140px] pointer-events-none" style="z-index:0;"></div>
<div class="fixed bottom-[-18rem] left-[-14rem] h-[38rem] w-[38rem] rounded-full bg-white/[0.035] blur-[140px] pointer-events-none" style="z-index:0;"></div>

  <!-- NAVBAR -->
  <nav class="fixed inset-x-0 top-0 z-[1000] border-b border-white/10 bg-[#08090b]/90 backdrop-blur-[20px]">
    <div class="mx-auto flex h-[76px] max-w-[1280px] items-center justify-between px-6 sm:px-12">
      <a href="/" class="font-orbitron text-[1.55rem] font-extrabold italic text-primary hover:drop-shadow-[0_0_18px_rgba(255,255,255,0.16)]">
        {{ name | default: "PenguinBy" }}
      </a>
      <ul class="hidden items-center gap-9 list-none lg:flex">
        <li><a href="#about" class="font-orbitron text-[0.94rem] font-bold text-muted hover:text-primary transition-colors">About</a></li>
        <li><a href="#pricing" class="font-orbitron text-[0.94rem] font-bold text-muted hover:text-primary transition-colors">Pricing</a></li>
        <li><a href="#support" class="font-orbitron text-[0.94rem] font-bold text-muted hover:text-primary transition-colors">Support</a></li>
        <li><a href="#faq" class="font-orbitron text-[0.94rem] font-bold text-muted hover:text-primary transition-colors">FAQ</a></li>
      </ul>
      <div class="flex items-center gap-4">
        <a href="/cart" class="relative font-mono text-[0.7rem] uppercase tracking-[0.18em] text-muted hover:text-primary transition-colors">
          Cart ({{ cartItems.items.length | default: 0 }})
        </a>
        <button id="menu-toggle" class="lg:hidden flex flex-col gap-1.5 p-2 bg-transparent border-0 cursor-pointer" aria-label="Toggle menu">
          <span class="block w-6 h-px bg-white transition-transform origin-center"></span>
          <span class="block w-6 h-px bg-white transition-opacity"></span>
          <span class="block w-6 h-px bg-white transition-transform origin-center"></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div id="mobile-menu">
    <a href="#about" onclick="document.getElementById('mobile-menu').classList.remove('open')">About</a>
    <a href="#pricing" onclick="document.getElementById('mobile-menu').classList.remove('open')">Pricing</a>
    <a href="#support" onclick="document.getElementById('mobile-menu').classList.remove('open')">Support</a>
    <a href="#faq" onclick="document.getElementById('mobile-menu').classList.remove('open')">FAQ</a>
    <a href="/cart" onclick="document.getElementById('mobile-menu').classList.remove('open')">Cart ({{ cartItems.items.length | default: 0 }})</a>
    <button onclick="document.getElementById('tos-modal').classList.add('open');document.getElementById('mobile-menu').classList.remove('open')">Terms</button>
    <button onclick="document.getElementById('refund-modal').classList.add('open');document.getElementById('mobile-menu').classList.remove('open')">Refunds</button>
  </div>

  <main class="relative z-10 pt-[76px]">
    {% comment %} PenguinBy Home / Store page {% endcomment %}

    <!-- HERO -->
    <section id="home" class="relative overflow-hidden px-6 pb-28 pt-[6rem] sm:px-12 lg:pt-[8rem]">
      <div class="absolute left-[30%] top-40 h-[42rem] w-[42rem] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(255,255,255,0.055),transparent_68%)] opacity-80"></div>
      <div class="mx-auto grid max-w-[1280px] items-center gap-16 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="relative z-10 max-w-[720px] animate-fade-up">
          <h1 class="font-orbitron text-[3rem] font-black leading-[1.15] text-white sm:text-[4.9rem] lg:text-[6rem]">
            Dominate
            <span class="mt-2 block bg-gradient-to-r from-white via-[#cfcfcf] to-[#747474] bg-clip-text pb-3 text-transparent">
              in games.
            </span>
          </h1>
          <p class="mt-8 max-w-[560px] text-[1.08rem] font-medium leading-[1.75] text-muted sm:text-[1.18rem]">
            {{ store.description | default: "PenguinBy delivers premium, feature-rich software access with real-time updates, fast setup, and 24/7 support." }}
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a href="#pricing" class="btn-primary rounded-[10px] px-8 py-4 font-mono text-[0.82rem] font-bold uppercase tracking-[0.1em] text-center">View Pricing</a>
            <a href="#about" class="btn-ghost rounded-[10px] px-8 py-4 font-mono text-[0.82rem] font-bold uppercase tracking-[0.1em] text-center">View Details</a>
          </div>
          <div class="mt-9 grid max-w-[720px] grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="flex items-center gap-3 rounded-lg border border-white/[0.08] bg-white/[0.03] px-4 py-3 text-muted">
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.12em]">Kernel-aware updates</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg border border-white/[0.08] bg-white/[0.03] px-4 py-3 text-muted">
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.12em]">Live status sync</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg border border-white/[0.08] bg-white/[0.03] px-4 py-3 text-muted">
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.12em]">Precision toolkit</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg border border-white/[0.08] bg-white/[0.03] px-4 py-3 text-muted">
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.12em]">Instant delivery</span>
            </div>
          </div>
        </div>
        <div class="relative z-10 mx-auto w-full max-w-[680px]">
          <div class="absolute inset-[-6rem] rounded-full bg-white/[0.045] blur-[100px]"></div>
          <div class="glass relative aspect-[16/9] w-full overflow-hidden rounded-xl">
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/80 to-transparent"></div>
            <div class="absolute inset-0 translate-y-[-100%] bg-gradient-to-b from-transparent via-primary/10 to-transparent animate-scan"></div>
            <div class="relative z-10 flex h-full gap-4 p-4 sm:p-6">
              <aside class="hidden w-[29%] flex-col gap-3 rounded-lg border border-white/5 bg-black/24 p-3 sm:flex">
                <div class="mb-2 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">Penguin Menu</div>
                <div class="rounded-md border border-white/5 bg-white/[0.025] px-3 py-2 font-mono text-[0.62rem] uppercase text-slate-500">Aimbot</div>
                <div class="rounded-md border border-primary/35 bg-primary/10 px-3 py-2 font-mono text-[0.62rem] uppercase text-primary">Visual ESP</div>
                <div class="rounded-md border border-white/5 bg-white/[0.025] px-3 py-2 font-mono text-[0.62rem] uppercase text-slate-500">Loot Radar</div>
                <div class="rounded-md border border-white/5 bg-white/[0.025] px-3 py-2 font-mono text-[0.62rem] uppercase text-slate-500">Recoil</div>
                <div class="rounded-md border border-white/5 bg-white/[0.025] px-3 py-2 font-mono text-[0.62rem] uppercase text-slate-500">Config</div>
              </aside>
              <div class="flex flex-1 flex-col gap-4">
                <div class="flex items-center justify-between rounded-lg border border-white/5 bg-black/20 px-4 py-3">
                  <div>
                    <div class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-stone-500">Selected Product</div>
                    <div class="mt-1 font-orbitron text-sm font-bold text-slate-200">Arc Raiders Pro</div>
                  </div>
                  <div class="flex items-center gap-2 rounded border border-red-300/25 bg-red-950/25 px-2 py-1 font-mono text-[0.6rem] uppercase text-red-200">
                    <span class="h-1.5 w-1.5 rounded-full bg-red-300"></span> Live
                  </div>
                </div>
                <div class="rounded-lg border border-white/5 bg-black/20 p-4 flex-1">
                  <div class="mb-4 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">Tactical Layer</div>
                  {% assign stats = "Player ESP:82,Loot ESP:74,Recoil:56,FOV Tuning:68" | split: "," %}
                  {% for stat in stats %}
                    {% assign parts = stat | split: ":" %}
                    <div class="mb-3">
                      <div class="mb-1 flex justify-between font-mono text-[0.58rem] uppercase tracking-[0.14em] text-stone-500">
                        <span>{{ parts[0] }}</span><span>{{ parts[1] }}%</span>
                      </div>
                      <div class="h-1.5 rounded-full bg-white/5">
                        <div class="h-full rounded-full bg-gradient-to-r from-white to-[#777]" style="width: {{ parts[1] }}%"></div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
            <div class="absolute bottom-4 left-4 z-20 rounded border border-primary/25 bg-[#171515]/90 px-3 py-2 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-primary">
              Status: Stable
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS BAR -->
    <div class="relative z-10 border-y border-white/[0.06] bg-[#0a0a0c]/70 px-6 py-8 sm:px-12">
      <div class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-center gap-x-16 gap-y-4 sm:justify-between">
        <div class="flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.14em] text-white/60">
          <span class="text-white font-bold text-[1.1rem] stat-number">99.9%</span> Uptime
        </div>
        <div class="flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.14em] text-white/60">
          <span class="text-white font-bold text-[1.1rem] stat-number">&lt;10min</span> Response
        </div>
        <div class="flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.14em] text-white/60">
          <span class="text-white font-bold text-[1.1rem] stat-number">24/7</span> Support
        </div>
        <div class="flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.14em] text-white/60">
          <span class="text-white font-bold text-[1.1rem] stat-number">Instant</span> Delivery
        </div>
      </div>
    </div>

    <!-- ABOUT / DETAILS -->
    <section id="about" class="relative overflow-hidden border-y border-white/[0.06] bg-[#090909]/80 px-6 py-20 sm:px-12">
      <div class="mx-auto max-w-[1280px]">
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-3 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-white/70">
            <span class="h-5 w-px bg-white/70"></span> About
          </div>
          <h2 class="max-w-[680px] font-orbitron text-[2.4rem] font-black leading-[1.04] text-white md:text-[3.4rem]">
            Built for clarity. Tuned for control.
          </h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {% assign features = "Visual ESP|Target, distance, and scene overlays with a clean tactical presentation.|Overlay module,Aimbot Tuning|Smoothing, FOV, and profile controls tuned for different play styles.|Precision module,Loot Radar|Item filters and priority reads surfaced without crowding the interface.|Intel module,Recoil Control|Compact presets and live sliders built into the same control surface.|Control module" | split: "," %}
          {% for f in features %}
            {% assign p = f | split: "|" %}
            <article class="glass rounded-2xl p-7 hover:-translate-y-1 transition-all">
              <div class="mb-3 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">{{ p[2] }}</div>
              <h3 class="font-orbitron text-[1.4rem] font-black text-white">{{ p[0] }}</h3>
              <p class="mt-3 text-[0.95rem] leading-7 text-muted">{{ p[1] }}</p>
            </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="relative overflow-hidden px-6 py-20 sm:px-12 reveal">
      <div class="mx-auto max-w-[1280px]">
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-3 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-primary">
            <span class="h-5 w-px bg-primary"></span> Why PenguinBy
          </div>
          <h2 class="max-w-[680px] font-orbitron text-[2.4rem] font-black leading-[1.04] text-white md:text-[3.4rem]">
            Everything you need, nothing you don't.
          </h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="glass rounded-2xl p-6 hover:-translate-y-1 transition-all">
            <div class="mb-3 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">01</div>
            <div class="font-orbitron text-[1.1rem] font-bold text-white">24/7 Support</div>
            <p class="mt-2 text-[0.88rem] leading-6 text-muted">Discord, tickets, and email — help when you need it.</p>
          </div>
          <div class="glass rounded-2xl p-6 hover:-translate-y-1 transition-all">
            <div class="mb-3 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">02</div>
            <div class="font-orbitron text-[1.1rem] font-bold text-white">Instant Delivery</div>
            <p class="mt-2 text-[0.88rem] leading-6 text-muted">Access granted immediately after payment clears.</p>
          </div>
          <div class="glass rounded-2xl p-6 hover:-translate-y-1 transition-all">
            <div class="mb-3 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">03</div>
            <div class="font-orbitron text-[1.1rem] font-bold text-white">Live Updates</div>
            <p class="mt-2 text-[0.88rem] leading-6 text-muted">Products updated for compatibility and safety.</p>
          </div>
          <div class="glass rounded-2xl p-6 hover:-translate-y-1 transition-all">
            <div class="mb-3 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">04</div>
            <div class="font-orbitron text-[1.1rem] font-bold text-white">Anti-Detect Layer</div>
            <p class="mt-2 text-[0.88rem] leading-6 text-muted">Built with evasion in mind from the ground up.</p>
          </div>
          <div class="glass rounded-2xl p-6 hover:-translate-y-1 transition-all">
            <div class="mb-3 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">05</div>
            <div class="font-orbitron text-[1.1rem] font-bold text-white">Custom Profiles</div>
            <p class="mt-2 text-[0.88rem] leading-6 text-muted">Save and switch between configs per game or playstyle.</p>
          </div>
          <div class="glass rounded-2xl p-6 hover:-translate-y-1 transition-all">
            <div class="mb-3 font-mono text-[0.6rem] uppercase tracking-[0.18em] text-primary">06</div>
            <div class="font-orbitron text-[1.1rem] font-bold text-white">Discord Community</div>
            <p class="mt-2 text-[0.88rem] leading-6 text-muted">Active community for setup help and updates.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRICING / PRODUCTS (auto from SellHub) -->
    <section id="pricing" class="relative overflow-hidden border-y border-white/[0.06] bg-[#080808]/90 px-6 py-24 sm:px-12 reveal">
      <div class="mx-auto max-w-[1280px]">
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-3 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-primary">
            <span class="h-5 w-px bg-primary"></span> Pricing
          </div>
          <h2 class="max-w-[680px] font-orbitron text-[2.4rem] font-black leading-[1.04] text-white md:text-[3.4rem]">
            Pick a duration. Get instant access.
          </h2>
        </div>

        {% if products and products.size > 0 %}
          <div class="grid gap-6 md:grid-cols-2">
            {% for product in products %}
              {% if product.hidden == false or product.hidden == nil %}
                <article class="glass rounded-3xl p-6 hover:-translate-y-1 transition-all">
                  {% if product.images and product.images[0] %}
                    <div class="aspect-[16/9] mb-5 overflow-hidden rounded-xl bg-black/40">
                      <img src="{{ product.images[0] }}" alt="{{ product.name }}" class="w-full h-full object-cover" />
                    </div>
                  {% endif %}
                  <div class="mb-2 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-primary">{{ product.displayedStatus | default: "Available" }}</div>
                  <h3 class="font-orbitron text-[1.6rem] font-black text-white">{{ product.name }}</h3>
                  <p class="mt-3 text-[0.95rem] leading-7 text-muted">{{ product.shortDescription | default: product.description }}</p>
                  <a href="{{ product.url }}" class="mt-6 btn-primary rounded-[10px] inline-block px-6 py-3 font-mono text-[0.78rem] font-bold uppercase tracking-[0.1em]">
                    View Pricing →
                  </a>
                </article>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="glass rounded-3xl p-8 text-center">
            <p class="text-muted">No products yet. Add products in your SellHub dashboard.</p>
          </div>
        {% endif %}
      </div>
    </section>

    <!-- SUPPORT / STATUS -->
    <section id="support" class="relative overflow-hidden px-6 py-24 sm:px-12 reveal">
      <div class="mx-auto max-w-[1280px] grid gap-7 lg:grid-cols-[1fr_0.86fr]">
        <div class="glass rounded-3xl p-7">
          <div class="mb-4 border-l-2 border-primary pl-4 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-primary">Support</div>
          <h2 class="font-orbitron text-[2.25rem] font-black leading-[1.04] text-white md:text-[3.2rem]">
            Clear help paths before and after checkout.
          </h2>
          <div class="mt-8 grid gap-3">
            <a href="https://discord.gg/HtSVra2rFS" target="_blank" rel="noopener" class="flex items-center gap-4 rounded-2xl border border-white/[0.08] bg-[#0d0d0f]/80 p-5 hover:-translate-y-0.5 hover:border-primary/25 transition-all">
              <div>
                <div class="font-orbitron text-[1.05rem] font-bold text-white">Discord</div>
                <div class="mt-1 text-[0.92rem] text-muted">Fastest path for setup help and account questions.</div>
              </div>
            </a>
            <a href="https://discord.gg/yfGvWcpydN" target="_blank" rel="noopener" class="flex items-center gap-4 rounded-2xl border border-white/[0.08] bg-[#0d0d0f]/80 p-5 hover:-translate-y-0.5 hover:border-primary/25 transition-all">
              <div>
                <div class="font-orbitron text-[1.05rem] font-bold text-white">Ticket System</div>
                <div class="mt-1 text-[0.92rem] text-muted">Use tickets for purchase, delivery, and technical issues.</div>
              </div>
            </a>
